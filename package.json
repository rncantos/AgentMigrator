{
  "name": "agent-migrator",
  "publisher": "dev",
  "displayName": "AgentMigrator",
  "description": "Migrate AI agents between Claude, Gemini, Copilot, etc.",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/rncantos/AgentMigrator" },
  "version": "0.0.15",
  "icon": "icon.jpg",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-migrator.migrate",
        "title": "AgentMigrator: Migrate AI Agent",
        "icon": "$(sync)"
      }
    ],
    "keybindings": [
      {
        "command": "agent-migrator.migrate",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorFocus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "agent-migrator.migrate",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "agent-migrator.migrate",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Agent Migrator",
      "properties": {
        "agentMigrator.defaultOrigin": {
          "type": "string",
          "enum": ["Claude", "Gemini", "Copilot", "None"],
          "default": "Claude",
          "description": "Default Origin AI to select in the migration panel."
        },
        "agentMigrator.defaultTarget": {
          "type": "string",
          "enum": ["Claude", "Gemini", "Copilot", "None"],
          "default": "Gemini",
          "description": "Default Target AI to select in the migration panel."
        },
        "agentMigrator.strictValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable strict schema validation before generating output."
        },
        "agentMigrator.ui.enableWowEffects": {
          "type": "boolean",
          "default": true,
          "description": "Enable premium glassmorphism and neon animations in the Webview."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "eslint": "^8.39.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  }
}
